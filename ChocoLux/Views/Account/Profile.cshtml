@model ChocoLux.Models.User
@{
    var isVi = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    ViewData["Title"] = isVi ? "Thông tin cá nhân" : "My Profile";
    var zones = ViewBag.ShippingZones as List<ChocoLux.Models.ShippingZone> ?? new();
    var isAdmin = (bool)(ViewBag.IsAdmin ?? false);
}

<div class="container my-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row g-4">
        <!-- THÔNG TIN CÁ NHÂN -->
        <div class="col-md-@(isAdmin ? "8 mx-auto" : "6")">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4" style="color:var(--choco-primary);">
                        <i class="bi bi-person-circle"></i> @(isVi ? "Thông tin cá nhân" : "My Profile")
                    </h4>
                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold">@(isVi ? "Họ và tên" : "Full Name")</label>
                            <input asp-for="FullName" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Phone" class="form-label fw-bold">@(isVi ? "Số điện thoại" : "Phone Number")</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary-choco px-4">
                            <i class="bi bi-save"></i> @(isVi ? "Lưu thay đổi" : "Save Changes")
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- FIX: ẩn địa chỉ giao hàng nếu là admin -->
        @if (!isAdmin)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <h4 class="fw-bold mb-4" style="color:var(--choco-primary);">
                            <i class="bi bi-geo-alt"></i> @(isVi ? "Địa chỉ giao hàng" : "Delivery Addresses")
                        </h4>

                        @if (Model.Addresses != null && Model.Addresses.Any())
                        {
                            foreach (var addr in Model.Addresses)
                            {
                                <div class="border rounded-3 p-3 mb-3 @(addr.IsDefault ? "border-warning bg-warning bg-opacity-10" : "")">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            @if (addr.IsDefault)
                                            {
                                                <span class="badge bg-warning text-dark mb-1"><i class="bi bi-star-fill"></i> @(isVi ? "Mặc định" : "Default")</span>
                                                <br />
                                            }
                                            <span>@addr.City?.CityNameVi</span><br />
                                            <span class="text-muted small">@addr.AddressDetail</span>
                                        </div>
                                        <div class="d-flex gap-2 ms-2 flex-shrink-0">
                                            @if (!addr.IsDefault)
                                            {
                                                <form asp-action="SetDefaultAddress" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="addressId" value="@addr.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="@(isVi ? "Đặt làm mặc định" : "Set as default")">
                                                        <i class="bi bi-star"></i>
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="DeleteAddress" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="addressId" value="@addr.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('@Html.Raw(isVi ? "Xóa địa chỉ này?" : "Delete this address?")')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted small">@(isVi ? "Chưa có địa chỉ nào." : "No addresses yet.")</p>
                        }

                        <!-- THÊM ĐỊA CHỈ MỚI - FIX: tỉnh/tp + địa chỉ chi tiết riêng -->
                        <button class="btn btn-outline-secondary btn-sm w-100 mt-2" type="button" data-bs-toggle="collapse" data-bs-target="#addAddressForm">
                            <i class="bi bi-plus-circle"></i> @(isVi ? "Thêm địa chỉ mới" : "Add New Address")
                        </button>
                        <div class="collapse mt-3" id="addAddressForm">
                            <form asp-action="AddAddress" method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label fw-bold">@(isVi ? "Tỉnh / Thành phố" : "City / Province")</label>
                                    <select name="cityId" class="form-select" required>
                                        <option value="">-- @(isVi ? "Chọn tỉnh thành" : "Select city") --</option>
                                        @foreach (var z in zones)
                                        {
                                            <option value="@z.Id">@(isVi? z.CityNameVi: z.CityName)</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">@(isVi ? "Địa chỉ chi tiết" : "Detailed Address")</label>
                                    <input type="text" name="addressDetail" class="form-control"
                                           placeholder="@(isVi ? "Số nhà, đường, phường/xã..." : "House number, street, ward...")" required />
                                </div>
                                <button type="submit" class="btn btn-primary-choco w-100">
                                    <i class="bi bi-save"></i> @(isVi ? "Lưu địa chỉ" : "Save Address")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>