@{
    var isVi = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    var isAdmin = User.IsInRole("ADMIN") || User.IsInRole("Admin");
    ViewData["Title"] = isVi ? "Trang chủ" : "Home";
}

<!-- HERO BANNER -->
<section style="background: linear-gradient(135deg, #4a2c2a 0%, #7b4a2d 60%, #c8860a 100%); min-height: 480px;"
         class="d-flex align-items-center">
    <div class="container text-white text-center py-5">
        <h1 class="display-4 fw-bold mb-3">
            @(isVi ? "Socola Nhập Khẩu Cao Cấp" : "Premium Imported Chocolate")
        </h1>
        <p class="lead mb-4">
            @(isVi ? "Trải nghiệm hương vị đẳng cấp từ Bỉ, Thụy Sĩ, Pháp" : "Experience world-class flavors from Belgium, Switzerland, France")
        </p>
        <a asp-controller="Product" asp-action="Index"
               class="btn btn-lg px-5 py-2 fw-bold"
               style="background:var(--choco-accent); color:white; border-radius:30px;">
            @(isVi ? "Khám phá ngay" : "Explore Now") <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</section>

<!-- SẢN PHẨM NỔI BẬT -->
<section class="container my-5">
    <h2 class="fw-bold mb-4 text-center" style="color:var(--choco-primary);">
        @(isVi ? "Sản Phẩm Nổi Bật" : "Featured Products")
    </h2>
    <div class="row g-4">
        @foreach (var p in ViewBag.FeaturedProducts)
        {
            <div class="col-6 col-md-3">
                <div class="card product-card h-100">
                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id" class="text-decoration-none text-reset d-block">
                        <img src="@p.MainImage" alt="@p.Name" />
                        <div class="card-body d-flex flex-column">
                            <p class="small text-muted mb-1">@p.Origin.CountryName</p>
                            <h6 class="fw-bold mb-1">@p.Name</h6>
                            <span class="price mb-0">@p.Price.ToString("N0") ₫</span>
                        </div>
                    </a>
                    @if (!isAdmin)
                    {
                        <div class="px-3 pb-3 mt-auto">
                            <button type="button" class="btn btn-sm btn-primary-choco w-100 btn-add-cart" data-id="@p.Id">
                                <i class="bi bi-cart-plus"></i> @(isVi ? "Thêm vào giỏ" : "Add to cart")
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
    <div class="text-center mt-4">
        <a asp-controller="Product" asp-action="Index"
               class="btn btn-primary-choco px-4 py-2">
            @(isVi ? "Xem tất cả sản phẩm" : "View All Products")
        </a>
    </div>
</section>

<!-- LÝ DO CHỌN CHÚNG TÔI -->
<section style="background:#fff8f0;" class="py-5">
    <div class="container">
        <h2 class="fw-bold text-center mb-4" style="color:var(--choco-primary);">
            @(isVi ? "Tại sao chọn ChocoLux?" : "Why Choose ChocoLux?")
        </h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <i class="bi bi-award fs-1" style="color:var(--choco-accent);"></i>
                <h5 class="mt-3">@(isVi ? "Chính hãng 100%" : "100% Authentic")</h5>
                <p class="text-muted small">
                    @(isVi ? "Nhập khẩu trực tiếp, có chứng nhận xuất xứ rõ ràng." : "Directly imported with certified country of origin.")
                </p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-truck fs-1" style="color:var(--choco-accent);"></i>
                <h5 class="mt-3">@(isVi ? "Giao hàng nhanh" : "Fast Delivery")</h5>
                <p class="text-muted small">
                    @(isVi ? "Giao hàng toàn quốc, đóng gói cẩn thận giữ nhiệt độ." : "Nationwide delivery, carefully packaged to maintain temperature.")
                </p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-shield-check fs-1" style="color:var(--choco-accent);"></i>
                <h5 class="mt-3">@(isVi ? "Bảo đảm chất lượng" : "Quality Guaranteed")</h5>
                <p class="text-muted small">
                    @(isVi ? "Hoàn tiền 100% nếu sản phẩm không đúng mô tả." : "100% refund if the product doesn't match the description.")
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Add-to-cart xử lý chung tại _Layout để ổn định cho mọi trang.
    </script>
}