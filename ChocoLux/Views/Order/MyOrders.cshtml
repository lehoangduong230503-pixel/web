@model List<ChocoLux.Models.Order>
@{
    var isVi = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    ViewData["Title"] = isVi ? "Đơn hàng của tôi" : "My Orders";
    var newOrder = Context.Request.Query["newOrder"].ToString() == "1";
}

<div class="container my-5">
    @Html.AntiForgeryToken()
    <h2 class="fw-bold mb-4" style="color:var(--choco-primary);">
        <i class="bi bi-bag-check"></i> @(isVi ? "Đơn hàng của tôi" : "My Orders")
    </h2>

    @if (newOrder)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>
            @(isVi ? "Đặt hàng thành công! Cảm ơn bạn đã mua hàng tại ChocoLux." : "Order placed successfully! Thank you for shopping at ChocoLux.")
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x fs-1 text-muted"></i>
            <p class="mt-3 text-muted">
                @(isVi ? "Bạn chưa có đơn hàng nào." : "You have no orders yet.")
                <a asp-controller="Product" asp-action="Index">@(isVi ? "Mua ngay!" : "Shop now!")</a>
            </p>
        </div>
    }
    else
    {
        <!-- Tab mới nhất lên đầu (đơn vừa đặt) -->
        @if (newOrder && Model.Any())
        {
            var latest = Model.First();
            var latestPayLabel = latest.Payment?.PaymentMethod switch
            {
                "COD" => "COD",
                "VNPay" => "VNPay",
                _ => ""
            };
            <div class="card border-success border-2 mb-4 shadow-sm">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @(isVi ? "Đơn hàng vừa đặt thành công" : "Order Just Placed Successfully")
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <p class="mb-1"><strong>@(isVi ? "Mã đơn:" : "Order Code:")</strong> @latest.OrderCode</p>
                            <p class="mb-1">
                                <strong>@(isVi ? "Tổng tiền:" : "Total:")</strong>
                                <span style="color:var(--choco-accent)">@latest.TotalAmount.ToString("N0") ₫</span>
                            </p>
                            <p class="mb-1"><strong>@(isVi ? "Thanh toán:" : "Payment:")</strong> @latestPayLabel</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1"><strong>@(isVi ? "Địa chỉ:" : "Ship to:")</strong> @latest.ShippingAddressSnapshot</p>
                            <p class="mb-1">
                                <strong>@(isVi ? "Trạng thái:" : "Status:")</strong>
                                <span class="badge bg-secondary">@(isVi ? "Chờ xử lý" : "Pending")</span>
                            </p>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <a href="/Order/OrderDetail/@latest.Id" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-eye"></i> @(isVi ? "Xem chi tiết" : "View Detail")
                        </a>
                        @if (latest.OrderStatus == "Pending")
                        {
                            <button class="btn btn-outline-danger btn-sm btn-cancel" data-id="@latest.Id">
                                <i class="bi bi-x-circle"></i> @(isVi ? "Hủy đơn" : "Cancel Order")
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table align-middle">
                <thead style="background:var(--choco-primary); color:white;">
                    <tr>
                        <th>@(isVi ? "Mã đơn" : "Order Code")</th>
                        <th>@(isVi ? "Ngày đặt" : "Date")</th>
                        <th>@(isVi ? "Địa chỉ giao" : "Ship To")</th>
                        <th>@(isVi ? "Tổng tiền" : "Total")</th>
                        <th>@(isVi ? "Thanh toán" : "Payment")</th>
                        <th>@(isVi ? "Trạng thái" : "Status")</th>
                        <th>@(isVi ? "Thao tác" : "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var statusLabel = o.OrderStatus switch
                        {
                            "Pending" => isVi ? "Chưa xử lý" : "Pending",
                            "Confirmed" => isVi ? "Đã xác nhận" : "Confirmed",
                            "Shipped" => isVi ? "Đang giao" : "Shipped",
                            "Completed" => isVi ? "Hoàn thành" : "Completed",
                            "PendingPayment" => isVi ? "Chờ thanh toán" : "Awaiting Payment",
                            "PaymentFailed" => isVi ? "Thanh toán thất bại" : "Payment Failed",
                            "Cancelled" => isVi ? "Đã hủy" : "Cancelled",
                            _ => o.OrderStatus
                        };
                        var statusClass = o.OrderStatus switch
                        {
                            "Completed" => "success",
                            "Shipped" => "info",
                            "Confirmed" => "primary",
                            "PaymentFailed" or "Cancelled" => "danger",
                            "PendingPayment" => "warning",
                            _ => "secondary"
                        };
                        var payLabel = o.Payment?.PaymentMethod switch
                        {
                            "COD" => "COD",
                            "VNPay" => "VNPay",
                            _ => ""
                        };
                        <tr>
                            <td><span class="fw-bold">@o.OrderCode</span></td>
                            <td>@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-truncate" style="max-width:160px;" title="@o.ShippingAddressSnapshot">@o.ShippingAddressSnapshot</td>
                            <td class="fw-bold" style="color:var(--choco-accent);">@o.TotalAmount.ToString("N0") ₫</td>
                            <td>@payLabel</td>
                            <td><span class="badge bg-@statusClass">@statusLabel</span></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <!-- FIX: nút xem chi tiết -->
                                    <a href="/Order/OrderDetail/@o.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <!-- FIX: nút hủy chỉ hiện khi Pending -->
                                    @if (o.OrderStatus == "Pending")
                                    {
                                        <button class="btn btn-sm btn-outline-danger btn-cancel" data-id="@o.Id"
                                                title="@(isVi ? "Hủy đơn" : "Cancel")">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $('.btn-cancel').click(function () {
            var id = $(this).data('id');
            var msg = '@Html.Raw(isVi ? "Bạn có chắc muốn hủy đơn hàng này?" : "Are you sure you want to cancel this order?")';
            if (!confirm(msg)) return;
            var token = $('input[name="__RequestVerificationToken"]').val() || '';
            $.post('/Order/CancelOrder', { orderId: id, __RequestVerificationToken: token }, function (res) {
                if (res.success) {
                    location.reload();
                } else {
                    alert(res.message || '@Html.Raw(isVi ? "Không thể hủy đơn hàng!" : "Cannot cancel order!")');
                }
            });
        });
    </script>
}