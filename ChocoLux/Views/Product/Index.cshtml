@model X.PagedList.IPagedList<Product>
@using X.PagedList.Mvc.Core

@{
    var isVi = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    var isAdmin = User.IsInRole("ADMIN") || User.IsInRole("Admin");
    ViewData["Title"] = isVi ? "Sản phẩm" : "Products";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4" style="color:var(--choco-primary);">
        @(isVi ? "Tất Cả Sản Phẩm" : "All Products")
    </h2>

    <!-- BỘ LỌC -->
    <form method="get" asp-action="Index" class="row g-2 mb-4 align-items-end">
        <div class="col-md-4">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control" placeholder="@(isVi ? "Tìm tên sản phẩm..." : "Search products...")" />
        </div>
        <div class="col-md-2">
            <select name="categoryId" class="form-select">
                <option value="">@(isVi ? "Tất cả loại" : "All types")</option>
                @{
                    var cats = ViewBag.Categories as List<ChocoLux.Models.Category> ?? new();
                    var selectedCatId = ViewBag.CategoryId?.ToString() ?? "";
                }
                @foreach (var cat in cats)
                {
                    var catSelected = selectedCatId == cat.Id.ToString() ? "selected" : null;
                    <option value="@cat.Id" selected="@catSelected">@cat.CategoryName</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="originId" class="form-select">
                <option value="">@(isVi ? "Tất cả xuất xứ" : "All origins")</option>
                @{
                    var origins = ViewBag.Origins as List<ChocoLux.Models.Origin> ?? new();
                    var selectedOriId = ViewBag.OriginId?.ToString() ?? "";
                }
                @foreach (var ori in origins)
                {
                    var oriSelected = selectedOriId == ori.Id.ToString() ? "selected" : null;
                    <option value="@ori.Id" selected="@oriSelected">@ori.CountryName</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="sort" class="form-select">
                <option value="">@(isVi ? "Sắp xếp giá" : "Sort by price")</option>
                @{
                    var sort = ViewBag.Sort?.ToString() ?? "";
                }
                <option value="asc" selected="@(sort == "asc" ? "selected" : null)">
                    @(isVi ? "Giá thấp → cao" : "Price: Low → High")
                </option>
                <option value="desc" selected="@(sort == "desc" ? "selected" : null)">
                    @(isVi ? "Giá cao → thấp" : "Price: High → Low")
                </option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary-choco w-100">
                @(isVi ? "Lọc" : "Filter")
            </button>
        </div>
    </form>

    <!-- DANH SÁCH SẢN PHẨM -->
    <div class="row g-4" id="product-list">
        @foreach (var p in Model)
        {
            <div class="col-6 col-md-3">
                <div class="card product-card h-100">
                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id" class="text-decoration-none text-reset d-block">
                        <img src="@p.MainImage" alt="@p.Name" />
                        <div class="card-body d-flex flex-column">
                            <span class="badge mb-1" style="background:var(--choco-primary);width:fit-content;">
                                @p.Origin.CountryName
                            </span>
                            <h6 class="fw-bold mb-1">@p.Name</h6>
                            <span class="price mb-0">@p.Price.ToString("N0") ₫</span>
                        </div>
                    </a>
                    @if (!isAdmin)
                    {
                        <div class="px-3 pb-3 mt-auto">
                            <button type="button" class="btn btn-sm btn-primary-choco w-100 btn-add-cart" data-id="@p.Id">
                                <i class="bi bi-cart-plus"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- PHÂN TRANG -->
    <div class="d-flex justify-content-center mt-5">
        @Html.PagedListPager(Model, page => Url.Action("Index", new
        {
            page,
            search = ViewBag.Search,
            categoryId = ViewBag.CategoryId,
            originId = ViewBag.OriginId,
            sort = ViewBag.Sort
        }), new X.PagedList.Mvc.Core.PagedListRenderOptions
        {
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            UlElementClasses = new[] { "pagination" }
        })
    </div>
</div>

@section Scripts {
    <script>
        // Add-to-cart xử lý chung tại _Layout để ổn định cho mọi trang.
    </script>
}
