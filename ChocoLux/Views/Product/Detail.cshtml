@model Product
@{
    ViewData["Title"] = Model.Name;
    var isVi = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    var isAdmin = User.IsInRole("ADMIN") || User.IsInRole("Admin");
    var description = isVi && !string.IsNullOrEmpty(Model.DescriptionVi) ? Model.DescriptionVi : Model.Description;
    var storageCondition = isVi && !string.IsNullOrEmpty(Model.StorageConditionVi) ? Model.StorageConditionVi : Model.StorageCondition;
    var remaining = Model.TotalStock - Model.SoldCount;
    if (remaining < 0) remaining = 0;
}

<div class="container my-5">
    <div class="row g-5">
        <div class="col-md-5">
            <img src="@Model.MainImage" class="img-fluid rounded-3 shadow" alt="@Model.Name" style="width:100%;" />
        </div>

        <div class="col-md-7">
            <span class="badge mb-2" style="background:var(--choco-primary);">@Model.Category.CategoryName</span>
            <h2 class="fw-bold" style="color:var(--choco-primary);">@Model.Name</h2>
            <p class="text-muted mb-1">
                <i class="bi bi-geo-alt"></i> @(isVi ? "Xuất xứ" : "Origin"): <strong>@Model.Origin.CountryName</strong>
            </p>
            <h3 class="my-3" style="color:var(--choco-accent);">@Model.Price.ToString("N0") ₫</h3>

            <!-- FIX: hiển thị số lượng còn lại -->
            <p class="mb-2">
                @if (remaining > 0)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle"></i>
                        @(isVi ? $"Còn lại: {remaining} sản phẩm" : $"In stock: {remaining}")
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        <i class="bi bi-x-circle"></i>
                        @(isVi ? "Hết hàng" : "Out of stock")
                    </span>
                }
            </p>

            <hr />

            <div class="mb-3">
                @Html.Raw(description)
            </div>

            @if (!string.IsNullOrEmpty(storageCondition))
            {
                <p class="text-muted small">
                    <i class="bi bi-thermometer-half"></i>
                    <strong>@(isVi ? "Bảo quản" : "Storage"):</strong> @storageCondition
                </p>
            }

            @if (!isAdmin && remaining > 0)
            {
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="input-group" style="width:130px;">
                        <button type="button" class="btn btn-outline-secondary" id="btn-minus">-</button>
                        <input type="number" id="quantity" value="1" min="1" max="@remaining" class="form-control text-center" />
                        <button type="button" class="btn btn-outline-secondary" id="btn-plus">+</button>
                    </div>
                    <button type="button" class="btn btn-primary-choco px-4 py-2 fw-bold" id="btn-add-detail" data-id="@Model.Id" data-max="@remaining">
                        <i class="bi bi-cart-plus"></i> @(isVi ? "Thêm vào giỏ" : "Add to cart")
                    </button>
                </div>
                <div id="add-result" class="text-success fw-bold" style="display:none;">
                    ✅ @(isVi ? "Đã thêm vào giỏ hàng!" : "Added to cart!")
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var maxQty = @remaining;
        $('#btn-plus').click(function () {
            var v = parseInt($('#quantity').val());
            if (v < maxQty) $('#quantity').val(v + 1);
        });
        $('#btn-minus').click(function () {
            var v = parseInt($('#quantity').val());
            if (v > 1) $('#quantity').val(v - 1);
        });

        $('#btn-add-detail').click(function () {
            var productId = $(this).data('id');
            var quantity = parseInt($('#quantity').val());
            $.post('/Cart/Add', { productId: productId, quantity: quantity }, function (res) {
                if (res.success) {
                    updateCartBadge(res.cartCount);
                    $('#add-result').fadeIn().delay(2000).fadeOut();
                }
            });
        });
    </script>
}