<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChocoLux</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root { --choco-primary: #4a2c2a; --choco-accent: #c8860a; --choco-light: #fff8f0; }
        body { font-family: 'Segoe UI', sans-serif; background-color: #fff; }
        .navbar { background-color: var(--choco-primary); }
        .navbar-brand { font-size: 1.6rem; font-weight: 700; color: var(--choco-accent) !important; letter-spacing: 1px; }
        .nav-link { color: #f5e6d3 !important; font-weight: 500; }
        .nav-link:hover { color: var(--choco-accent) !important; }
        .btn-cart { background-color: var(--choco-accent); color: white; border-radius: 20px; padding: 5px 16px; font-weight: 600; }
        .btn-cart:hover { background-color: #a06e08; color: white; }
        footer { background-color: var(--choco-primary); color: #f5e6d3; padding: 30px 0; margin-top: 60px; }
        footer a { color: var(--choco-accent); text-decoration: none; }
        .product-card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(74,44,42,0.10); transition: transform 0.2s, box-shadow 0.2s; overflow: hidden; cursor: pointer; }
        .product-card:hover { transform: translateY(-5px); box-shadow: 0 8px 24px rgba(74,44,42,0.18); }
        .product-card img { height: 220px; object-fit: cover; width: 100%; }
        .product-card .card-body { padding: 16px; }
        .product-card .price { color: var(--choco-accent); font-weight: 700; font-size: 1.1rem; }
        .btn-primary-choco { background-color: var(--choco-primary); color: white; border: none; border-radius: 8px; }
        .btn-primary-choco:hover { background-color: var(--choco-accent); color: white; }
        .cart-badge { position: relative; }
        .cart-badge .badge { position: absolute; top: -8px; right: -8px; background: red; color: white; border-radius: 50%; font-size: 0.7rem; padding: 3px 6px; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var currentPath = Context.Request.Path + Context.Request.QueryString;
        var langLabel = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName.ToUpper();
        var isVi = langLabel == "VI";
        var isAdmin = User.IsInRole("ADMIN") || User.IsInRole("Admin");
    }

    <nav class="navbar navbar-expand-lg sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">ChocoLux</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
<span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">@(isVi ? "Trang chủ" : "Home")</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">@(isVi ? "Sản phẩm" : "Products")</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">

                    @* Chỉ hiện giỏ hàng cho khách, không hiện cho admin *@
                    @if (!User.IsInRole("ADMIN") && !User.IsInRole("Admin"))
                    {
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-cart cart-badge">
                            <i class="bi bi-cart3"></i> @(isVi ? "Giỏ hàng" : "Cart")
                            <span class="badge" id="cart-count" style="display:none;"></span>
                        </a>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">@langLabel</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("SetLanguage", "Home", new { culture = "vi", returnUrl = currentPath })">&#x1F1FB;&#x1F1F3; Tiếng Việt</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("SetLanguage", "Home", new { culture = "en", returnUrl = currentPath })">&#x1F1EC;&#x1F1E7; English</a></li>
                            </ul>
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-light dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (isAdmin)
                                {
                                    <li><a class="dropdown-item fw-bold" asp-controller="AdminProduct" asp-action="Index"><i class="bi bi-speedometer2"></i> @(isVi ? "Trang quản trị" : "Admin Panel")</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person"></i> @(isVi ? "Thông tin cá nhân" : "My Profile")</a></li>
                                @if (!isAdmin)
{
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="MyOrders"><i class="bi bi-bag"></i> @(isVi ? "Đơn hàng của tôi" : "My Orders")</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button class="dropdown-item text-danger" type="submit"><i class="bi bi-box-arrow-right"></i> @(isVi ? "Đăng xuất" : "Logout")</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown">@langLabel</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("SetLanguage", "Home", new { culture = "vi", returnUrl = currentPath })">&#x1F1FB;&#x1F1F3; Tiếng Việt</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("SetLanguage", "Home", new { culture = "en", returnUrl = currentPath })">&#x1F1EC;&#x1F1E7; English</a></li>
                            </ul>
                        </div>

                        <!-- ✅ FIX: Dùng Unicode thực thay vì HTML entities trong Razor string -->
                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-light">@(isVi ? "Đăng nhập" : "Login")</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-sm" style="background:var(--choco-accent);color:white;">@(isVi ? "Đăng ký" : "Register")</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>@RenderBody()</main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5 style="color:var(--choco-accent);">ChocoLux</h5>
                    <p class="small">@(isVi ? "Socola nhập khẩu cao cấp từ Bỉ, Thụy Sĩ, Pháp." : "Premium imported chocolate from Belgium, Switzerland, France.")</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>@(isVi ? "Liên kết" : "Links")</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/">@(isVi ? "Trang chủ" : "Home")</a></li>
                        <li><a asp-controller="Product" asp-action="Index">@(isVi ? "Sản phẩm" : "Products")</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>@(isVi ? "Liên hệ" : "Contact")</h6>
                    <p class="small mb-1"><i class="bi bi-envelope"></i> choco@chocolux.vn</p>
                    <p class="small"><i class="bi bi-telephone"></i> 0909 123 456</p>
                </div>
            </div>
            <hr style="border-color:#6b3d3a;">
            <p class="text-center small mb-0">&copy; 2025 ChocoLux. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script>
        function updateCartBadge(count) {
            var $badge = $('#cart-count');
if (count > 0) {
                $badge.text(count).show();
            } else {
                $badge.text('').hide();
            }
        }

        function refreshCartBadge() {
            $.get('/Cart/GetCart', function (data) {
                updateCartBadge(data.totalItems || 0);
            });
        }

        @if (!isAdmin)
        {
            <text>
            $(document).ready(function () {
                refreshCartBadge();
            });

            $(document).on('click', '.btn-add-cart', function (e) {
                e.preventDefault();
                e.stopPropagation();

                var $btn = $(this);
                var productId = $btn.data('id');
                if (!productId) return;

                if ($btn.prop('disabled')) return;
                $btn.prop('disabled', true);

                $.post('/Cart/Add', { productId: productId, quantity: 1 })
                    .done(function (res) {
                        if (res && res.success) {
                            updateCartBadge(res.cartCount || 0);
                            $btn.html('<i class="bi bi-check"></i>');
                        } else {
                            alert((res && res.message) ? res.message : 'Không thể thêm sản phẩm vào giỏ.');
                        }
                    })
                    .fail(function () {
                        alert('Lỗi kết nối, vui lòng thử lại.');
                    })
                    .always(function () {
                        setTimeout(function () {
                            $btn.html('<i class="bi bi-cart-plus"></i>');
                            $btn.prop('disabled', false);
                        }, 800);
                    });
            });
            </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>